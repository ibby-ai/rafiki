# Optional: Proxy Auth headers for local Makefile and HTTP example scripts.
MODAL_PROXY_KEY=wk-your-modal-proxy-key
MODAL_PROXY_SECRET=ws-your-modal-proxy-secret

# Runtime tuning
RETRY_MAX_ATTEMPTS=3
ENABLE_MEMORY_SNAPSHOT=true
VOLUME_COMMIT_INTERVAL=60
MIN_CONTAINERS=1
MAX_CONTAINERS=4
BUFFER_CONTAINERS=1
CONCURRENT_TARGET_INPUTS=5
CONCURRENT_MAX_INPUTS=10

# Optional: enable LangSmith tracing. For Modal-backed runtime, the key normally
# comes from Modal secret `langsmith-secret`; pure local runs can still export
# `LANGSMITH_API_KEY` and `LANGSMITH_PROJECT` directly if needed.
ENABLE_LANGSMITH_TRACING=true

# Required locally at import/build time; deployed function runtime also receives
# the matching value from Modal secret `internal-auth-secret`.
INTERNAL_AUTH_SECRET=replace-with-shared-internal-auth-secret

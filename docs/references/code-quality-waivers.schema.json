{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rafiki Code Quality Waivers",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "waivers"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "rule",
          "scope",
          "owner",
          "reason",
          "expires_on",
          "tracking_ref"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "expires_on": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "tracking_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

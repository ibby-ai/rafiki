{
  "name": "rafiki-control-plane",
  "version": "1.0.0",
  "description": "Cloudflare Worker + Durable Objects control plane for Rafiki",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --env development",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "deploy:development": "wrangler deploy --env development",
    "tail:development": "wrangler tail --env development",
    "types": "wrangler types",
    "check": "ultracite check",
    "check:boundaries": "depcruise --config dependency-cruiser.cjs src",
    "check:contracts": "tsx --test tests/contracts/**/*.test.ts",
    "docs:api": "typedoc --options typedoc.contracts.json",
    "fix": "ultracite fix",
    "test:integration": "tsx --test tests/integration/**/*.test.ts"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "agent",
    "modal"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250115.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "dependency-cruiser": "^16.10.4",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.13",
    "typescript": "^5.7.2",
    "ultracite": "^7.2.4",
    "wrangler": "^3.95.0"
  }
}
